{
  "name": "ai-agent-workflows",
  "version": "1.0.0",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node src/index.ts",
    "dev:api": "ts-node src/server.ts",
    "build": "tsc",
    "lint": "tsc --noEmit",
    "test": "npm run build && node --test dist/test/**/*.test.js",
    "evals": "RUN_STORAGE_DIR=.eval-runs ts-node src/evals/runEvals.ts",
    "evals:report": "RUN_STORAGE_DIR=.eval-runs ts-node src/evals/runEvals.ts --output .eval-reports/latest.json",
    "evals:baseline": "ts-node src/evals/createEvalBaseline.ts --report .eval-reports/latest.json --output evals/baseline.json",
    "evals:refresh-baseline": "npm run evals:report && npm run evals:baseline",
    "evals:compare": "ts-node src/evals/compareEvalReports.ts",
    "evals:gate": "npm run evals:report && npm run evals:compare -- --baseline evals/baseline.json --candidate .eval-reports/latest.json",
    "ci:local": "bash ./scripts/ci-local.sh",
    "start:api": "node dist/server.js"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "dotenv": "^16.0.0",
    "express": "^5.2.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "ts-node": "^10.0.0",
    "typescript": "^5.0.0"
  }
}
